# Copy this file to .env and fill in your own Supabase project credentials.
# Get these from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Optional: Discord webhook URL for contact message notifications
# Leave blank to disable. Note: this will be visible in client JS bundles —
# use a Discord webhook that only posts to a private channel.
VITE_DISCORD_WEBHOOK_URL=""
